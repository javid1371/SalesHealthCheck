# PostgreSQL connection string
# Local Docker: postgresql://postgres:postgres@localhost:5432/sales_health_check
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sales_health_check"

# Report Engine: CTA routing (`free` | `full`). Defaults to `free` when unset.
# CAPACITY_MODE="free"

# Internal Expert View admin token (required in production)
# EXPERT_VIEW_TOKEN="your-secret-token"

# Public URL (required in production for recovery emails)
# APP_BASE_URL="http://localhost:3000"

# Email recovery via Resend (optional in dev)
# RESEND_API_KEY="re_xxxxxxxx"
# EMAIL_FROM="noreply@yourdomain.com"

# Error monitoring via Sentry (production only — set both to the same DSN)
# SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"

# PDF export via Playwright (optional — requires: npx playwright install chromium)
# PDF_GENERATION_ENABLED=true
