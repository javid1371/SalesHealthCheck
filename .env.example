# PostgreSQL connection string
# Local Docker: postgresql://postgres:postgres@localhost:5432/sales_health_check
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sales_health_check"

# Report Engine: CTA routing (`free` | `full`). Defaults to `free` when unset.
# CAPACITY_MODE="free"

# Internal Expert View admin token (required in production)
# EXPERT_VIEW_TOKEN="your-secret-token"

# Public URL (required in production for recovery emails)
# APP_BASE_URL="http://localhost:3000"

# Email recovery via Resend (optional in dev)
# RESEND_API_KEY="re_xxxxxxxx"
# EMAIL_FROM="noreply@yourdomain.com"

# Error monitoring via Sentry (production only — set both to the same DSN)
# SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"

# PDF export via Playwright (optional — requires: npx playwright install chromium)
# PDF_GENERATION_ENABLED=true

# OTP auth + signed session cookies (ADR 0014 — required when auth routes are enabled)
# AUTH_SESSION_SECRET="generate-a-long-random-string"

# Kavenegar SMS for OTP (optional in dev — codes are logged when unset)
# KAVENEGAR_API_KEY="your-kavenegar-api-key"
# KAVENEGAR_OTP_TEMPLATE="verify"

# Admin panel login (set one of ADMIN_PASSWORD or ADMIN_PASSWORD_HASH)
# ADMIN_PASSWORD="change-me-in-production"
# ADMIN_PASSWORD_HASH=""

# Sales expert panel — consultation leads (set one of SALES_EXPERT_PASSWORD or SALES_EXPERT_PASSWORD_HASH)
# SALES_EXPERT_PASSWORD="change-me-for-sales-team"
# SALES_EXPERT_PASSWORD_HASH=""

# OTP policy (optional — defaults shown)
# OTP_TTL_SECONDS=300
# OTP_MAX_ATTEMPTS=3

# Telegram / Bale messenger bots (optional — dev mode logs outbound messages)
# TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
# TELEGRAM_WEBHOOK_SECRET="random-webhook-secret"
# BALE_BOT_TOKEN="your-bale-bot-token"
# BALE_WEBHOOK_SECRET="random-webhook-secret"

# SMS sales funnel (requires Redis + npm run worker:sms-funnel)
# REDIS_URL="redis://localhost:6379"
# SMS_FUNNEL_ENABLED=true
# KAVENEGAR_SENDER_LINE="1000XXXX"
# SMS_QUIET_HOURS_START=9
# SMS_QUIET_HOURS_END=21
# SMS_FUNNEL_MAX_UNANSWERED=4
# SMS_FUNNEL_CRON_SECRET="generate-a-long-random-string"
