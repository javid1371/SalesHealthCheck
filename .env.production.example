# Production environment for docker-compose.nginx.yml or docker-compose.prod.yml
# Copy to .env on the VPS and edit secrets before first deploy.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sales_health_check

APP_PORT=3105
APP_DOMAIN=health.example.com
APP_BASE_URL=https://health.example.com

# Prebuilt image from GitHub Actions (GHCR)
APP_IMAGE=ghcr.io/javid1371/sales-health-check:latest

EXPERT_VIEW_TOKEN=generate-with-openssl-rand-hex-32
AUTH_SESSION_SECRET=generate-with-openssl-rand-hex-32
CAPACITY_MODE=free

# OTP SMS (Kavenegar)
# KAVENEGAR_API_KEY=
# KAVENEGAR_OTP_TEMPLATE=

# Admin panel — set one of:
# ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH=

# Sales expert panel (consultation leads) — set one of:
# SALES_EXPERT_PASSWORD=
# SALES_EXPERT_PASSWORD_HASH=

# Email recovery (optional)
# RESEND_API_KEY=
# EMAIL_FROM=noreply@example.com

# PDF export (requires Playwright in image — set PDF_GENERATION_ENABLED=true in CI vars)
# PDF_GENERATION_ENABLED=true

# Sentry (optional — baked into image at build time via CI secrets)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# Telegram / Bale messenger bots (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# BALE_BOT_TOKEN=
# BALE_WEBHOOK_SECRET=

# SMS sales funnel
# SMS_FUNNEL_ENABLED=true
# KAVENEGAR_SENDER_LINE=
# SMS_QUIET_HOURS_START=9
# SMS_QUIET_HOURS_END=21
# SMS_FUNNEL_MAX_UNANSWERED=4
# SMS_FUNNEL_CRON_SECRET=
# SMS_FUNNEL_WORKER_CONCURRENCY=5

# Auto lead assignment to sales experts (round-robin + SMS notification)
# LEAD_AUTO_ASSIGN_ENABLED=true
# LEAD_SYSTEM_ASSIGN_DELAY_HOURS=24

# Cron routes (/api/cron/*) share SMS_FUNNEL_CRON_SECRET — install host cron via:
#   chmod +x scripts/install-vps-crons.sh scripts/vps-cron-call.sh
#   ./scripts/install-vps-crons.sh
