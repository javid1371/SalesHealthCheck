generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ModelVersionStatus {
  draft
  active
  archived
}

enum AssessmentStatus {
  started
  in_progress
  completed
  abandoned
}

enum HealthLevel {
  critical
  weak
  medium
  healthy
}

enum ReportStatus {
  generated
  ai_enhanced
  failed
}

enum DiagnosisSeverity {
  low
  medium
  high
  critical
}

enum SalesModel {
  online
  offline
  phone
  direct_message
  hybrid
}

enum StaffRole {
  admin
  sales_expert
}

enum LeadStatus {
  new
  contacted
  meeting_scheduled
  closed_won
  closed_lost
  unreachable
}

enum LeadSource {
  direct
  system
  messenger
}

enum LeadActivityType {
  created
  status_change
  assignment_change
  note_added
  probability_override
  follow_up_set
}

enum PurchaseProbability {
  low
  medium
  high
}

enum ActionPlanTimeframe {
  seven_days
  thirty_days
}

enum MessengerPlatform {
  telegram
  bale
}

enum BotConversationState {
  idle
  awaiting_contact
  at_main_menu
  selecting_report
  awaiting_consultation_message
  awaiting_business_name
  awaiting_team_size
  awaiting_sales_model
  answering_questions
  completed
}

enum SmsStatus {
  pending
  sent
  failed
  canceled
  skipped
}

enum EnrollmentStatus {
  active
  completed
  stopped
  converted
}

enum ScoreBand {
  low
  medium
  high
}

enum FunnelEventType {
  report_viewed
  link_clicked
  cta_clicked
  consultation_started
  sms_sent
  opt_out
}

enum ShortLinkPurpose {
  start
  continue_assessment
  result
  consultation
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?
  phone           String?
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organizations      Organization[]
  assessmentSessions AssessmentSession[]
  funnelEnrollments  FunnelEnrollment[]
  funnelEvents       FunnelEvent[]
  shortLinks         ShortLink[]

  @@map("users")
}

model Organization {
  id           String      @id @default(cuid())
  userId       String      @map("user_id")
  businessName String      @map("business_name")
  industry     String?
  teamSize     String?     @map("team_size")
  salesModel   SalesModel? @map("sales_model")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentSessions AssessmentSession[]

  @@map("organizations")
}

model ModelVersion {
  id                     String             @id @default(cuid())
  name                   String
  versionNumber          String             @map("version_number")
  status                 ModelVersionStatus @default(draft)
  diagnosisEngineVersion String             @default("v1") @map("diagnosis_engine_version")
  createdAt              DateTime           @default(now()) @map("created_at")
  activatedAt            DateTime?          @map("activated_at")

  domains            Domain[]
  layers             Layer[]
  questions          Question[]
  diagnosticRules    DiagnosticRule[]
  assessmentSessions AssessmentSession[]

  @@map("model_versions")
}

model Layer {
  id             String  @id @default(cuid())
  modelVersionId String  @map("model_version_id")
  name           String
  slug           String
  description    String?
  displayOrder   Int     @map("display_order")

  modelVersion ModelVersion @relation(fields: [modelVersionId], references: [id], onDelete: Cascade)
  domains      Domain[]
  layerScores  LayerScore[]

  @@unique([modelVersionId, slug])
  @@map("layers")
}

model Domain {
  id             String  @id @default(cuid())
  modelVersionId String  @map("model_version_id")
  layerId        String  @map("layer_id")
  name           String
  slug           String
  description    String?
  weight         Float
  displayOrder   Int     @map("display_order")
  isActive       Boolean @default(true) @map("is_active")

  modelVersion ModelVersion  @relation(fields: [modelVersionId], references: [id], onDelete: Cascade)
  layer        Layer         @relation(fields: [layerId], references: [id], onDelete: Cascade)
  questions    Question[]
  domainScores DomainScore[]
  bottlenecks  Bottleneck[]

  @@unique([modelVersionId, slug])
  @@map("domains")
}

model Question {
  id             String  @id @default(cuid())
  modelVersionId String  @map("model_version_id")
  domainId       String  @map("domain_id")
  text           String
  helpText       String? @map("help_text")
  displayOrder   Int     @map("display_order")
  isActive       Boolean @default(true) @map("is_active")

  modelVersion ModelVersion     @relation(fields: [modelVersionId], references: [id], onDelete: Cascade)
  domain       Domain           @relation(fields: [domainId], references: [id], onDelete: Cascade)
  options      QuestionOption[]
  answers      Answer[]

  @@map("questions")
}

model QuestionOption {
  id              String  @id @default(cuid())
  questionId      String  @map("question_id")
  text            String
  score           Int
  displayOrder    Int     @map("display_order")
  messengerLabel  String? @map("messenger_label") @db.VarChar(64)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  Answer[]

  @@map("question_options")
}

model DiagnosticRule {
  id              String  @id @default(cuid())
  modelVersionId  String  @map("model_version_id")
  name            String
  description     String?
  conditionType   String  @map("condition_type")
  conditionConfig Json    @map("condition_config")
  diagnosisKey    String  @map("diagnosis_key")
  priority        Int     @default(0)
  isActive        Boolean @default(true) @map("is_active")

  modelVersion ModelVersion @relation(fields: [modelVersionId], references: [id], onDelete: Cascade)

  @@map("diagnostic_rules")
}

model AssessmentSession {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  organizationId String           @map("organization_id")
  modelVersionId String           @map("model_version_id")
  status         AssessmentStatus @default(started)
  resultToken         String           @unique @map("result_token")
  structuredDiagnosis Json?            @map("structured_diagnosis")
  monthlyRevenue      Float?           @map("monthly_revenue")
  averageOrderValue   Float?           @map("average_order_value")
  monthlyLeads        Float?           @map("monthly_leads")
  repeatPurchaseRate  Float?           @map("repeat_purchase_rate")
  startedAt           DateTime         @default(now()) @map("started_at")
  completedAt    DateTime?        @map("completed_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modelVersion ModelVersion  @relation(fields: [modelVersionId], references: [id])
  answers      Answer[]
  domainScores DomainScore[]
  layerScores  LayerScore[]
  overallScore OverallScore?
  bottlenecks  Bottleneck[]
  diagnoses    Diagnosis[]
  report               Report?
  actionPlans          ActionPlan[]
  consultationRequests ConsultationRequest[]
  funnelEnrollments    FunnelEnrollment[]
  funnelEvents         FunnelEvent[]
  shortLinks           ShortLink[]

  @@index([status])
  @@map("assessment_sessions")
}

model Answer {
  id                  String   @id @default(cuid())
  assessmentSessionId String   @map("assessment_session_id")
  questionId          String   @map("question_id")
  selectedOptionId    String   @map("selected_option_id")
  scoreSnapshot       Int      @map("score_snapshot")
  answeredAt          DateTime @default(now()) @map("answered_at")

  assessmentSession AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  question          Question          @relation(fields: [questionId], references: [id])
  selectedOption    QuestionOption    @relation(fields: [selectedOptionId], references: [id])

  @@unique([assessmentSessionId, questionId])
  @@map("answers")
}

model DomainScore {
  id                  String      @id @default(cuid())
  assessmentSessionId String      @map("assessment_session_id")
  domainId            String      @map("domain_id")
  rawScore            Int         @map("raw_score")
  maxScore            Int         @map("max_score")
  percentage          Float
  healthLevel         HealthLevel @map("health_level")

  assessmentSession AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  domain            Domain            @relation(fields: [domainId], references: [id])

  @@unique([assessmentSessionId, domainId])
  @@map("domain_scores")
}

model LayerScore {
  id                  String      @id @default(cuid())
  assessmentSessionId String      @map("assessment_session_id")
  layerId             String      @map("layer_id")
  rawScore            Int         @map("raw_score")
  maxScore            Int         @map("max_score")
  percentage          Float
  healthLevel         HealthLevel @map("health_level")

  assessmentSession AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  layer             Layer             @relation(fields: [layerId], references: [id])

  @@unique([assessmentSessionId, layerId])
  @@map("layer_scores")
}

model OverallScore {
  id                  String      @id @default(cuid())
  assessmentSessionId String      @unique @map("assessment_session_id")
  rawScore            Int         @map("raw_score")
  maxScore            Int         @map("max_score")
  percentage          Float
  healthLevel         HealthLevel @map("health_level")

  assessmentSession AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)

  @@map("overall_scores")
}

model Bottleneck {
  id                  String @id @default(cuid())
  assessmentSessionId String @map("assessment_session_id")
  domainId            String @map("domain_id")
  weaknessScore       Float  @map("weakness_score")
  domainWeight        Float  @map("domain_weight")
  priorityScore       Float  @map("priority_score")
  rank                Int

  assessmentSession AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  domain            Domain            @relation(fields: [domainId], references: [id])
  actionPlans       ActionPlan[]

  @@unique([assessmentSessionId, rank])
  @@map("bottlenecks")
}

model Diagnosis {
  id                  String            @id @default(cuid())
  assessmentSessionId String            @map("assessment_session_id")
  diagnosisKey        String            @map("diagnosis_key")
  title               String
  description         String
  severity            DiagnosisSeverity
  priority            Int               @default(0)
  relatedDomainIds    Json              @default("[]") @map("related_domain_ids")
  relatedLayerIds     Json              @default("[]") @map("related_layer_ids")

  assessmentSession AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  actionPlans       ActionPlan[]

  @@map("diagnoses")
}

model Report {
  id                  String       @id @default(cuid())
  assessmentSessionId String       @unique @map("assessment_session_id")
  reportStatus        ReportStatus @default(generated) @map("report_status")
  structuredReport    Json         @map("structured_report")
  reportSpec          Json?        @map("report_spec")
  aiGeneratedText     String?      @map("ai_generated_text")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  assessmentSession    AssessmentSession     @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  consultationRequests ConsultationRequest[]

  @@map("reports")
}

model ConsultationRequest {
  id                        String               @id @default(cuid())
  assessmentSessionId       String?              @map("assessment_session_id")
  reportId                  String?              @map("report_id")
  name                      String
  email                     String?
  phone                     String?
  message                   String?
  status                    LeadStatus           @default(new)
  source                    LeadSource           @default(direct)
  purchaseProbabilityPercent Int?                @map("purchase_probability_percent")
  purchaseProbabilityBand   PurchaseProbability? @map("purchase_probability_band")
  assignedToId              String?              @map("assigned_to_id")
  assignScheduledFor              DateTime?            @map("assign_scheduled_for")
  nextFollowUpAt                  DateTime?            @map("next_follow_up_at")
  firstContactedAt                DateTime?            @map("first_contacted_at")
  closedAt                        DateTime?            @map("closed_at")
  adminProbabilityOverridePercent Int?                 @map("admin_probability_override_percent")
  createdAt                       DateTime             @default(now()) @map("created_at")
  updatedAt                       DateTime             @updatedAt @map("updated_at")

  assessmentSession AssessmentSession? @relation(fields: [assessmentSessionId], references: [id], onDelete: SetNull)
  report            Report?            @relation(fields: [reportId], references: [id], onDelete: SetNull)
  assignedTo        StaffUser?         @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  consultationNotes ConsultationNote[]
  leadActivities    LeadActivity[]

  @@index([assessmentSessionId])
  @@index([createdAt])
  @@index([assignedToId])
  @@index([status])
  @@index([source])
  @@index([assignScheduledFor, assignedToId, source])
  @@map("consultation_requests")
}

model StaffUser {
  id              String    @id @default(cuid())
  name            String
  phone           String    @unique
  passwordHash    String    @map("password_hash")
  role            StaffRole
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  lastAssignedAt  DateTime? @map("last_assigned_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  assignedLeads     ConsultationRequest[] @relation("LeadAssignee")
  consultationNotes ConsultationNote[]
  leadActivities    LeadActivity[]

  @@map("staff_users")
}

model ConsultationNote {
  id                    String   @id @default(cuid())
  consultationRequestId String   @map("consultation_request_id")
  staffUserId           String   @map("staff_user_id")
  body                  String
  createdAt             DateTime @default(now()) @map("created_at")

  consultationRequest ConsultationRequest @relation(fields: [consultationRequestId], references: [id], onDelete: Cascade)
  staffUser           StaffUser           @relation(fields: [staffUserId], references: [id])

  @@index([consultationRequestId])
  @@map("consultation_notes")
}

model ActionPlan {
  id                  String              @id @default(cuid())
  assessmentSessionId String              @map("assessment_session_id")
  diagnosisId         String?             @map("diagnosis_id")
  bottleneckId        String?             @map("bottleneck_id")
  timeframe           ActionPlanTimeframe
  title               String
  description         String
  priority            Int                 @default(0)

  assessmentSession AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  diagnosis         Diagnosis?        @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  bottleneck        Bottleneck?       @relation(fields: [bottleneckId], references: [id], onDelete: SetNull)

  @@map("action_plans")
}

model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  attempts   Int       @default(0)
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([phone])
  @@map("otp_codes")
}

model BotConversation {
  id                   String               @id @default(cuid())
  platform             MessengerPlatform
  chatId               String               @map("chat_id")
  userId               String?              @map("user_id")
  assessmentId         String?              @map("assessment_id")
  state                BotConversationState @default(idle)
  currentDomainIndex   Int                  @default(0) @map("current_domain_index")
  currentQuestionIndex Int                  @default(0) @map("current_question_index")
  lastPromptMessageId  String?              @map("last_prompt_message_id")
  contactFirstName     String?              @map("contact_first_name")
  businessName         String?              @map("business_name")
  teamSize             String?              @map("team_size")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  @@unique([platform, chatId])
  @@map("bot_conversations")
}

model SmsMessage {
  id                String     @id @default(cuid())
  phone             String
  body              String
  status            SmsStatus  @default(pending)
  sequenceKey       String     @map("sequence_key")
  stepKey           String     @map("step_key")
  enrollmentId      String     @map("enrollment_id")
  dedupeKey         String     @unique @map("dedupe_key")
  providerMessageId String?    @map("provider_message_id")
  scheduledFor      DateTime   @map("scheduled_for")
  sentAt            DateTime?  @map("sent_at")
  error             String?
  createdAt         DateTime   @default(now()) @map("created_at")

  enrollment FunnelEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([phone])
  @@map("sms_messages")
}

model FunnelEnrollment {
  id                  String           @id @default(cuid())
  userId              String           @map("user_id")
  assessmentSessionId String?          @map("assessment_session_id")
  sequenceKey         String           @map("sequence_key")
  currentStep         String?          @map("current_step")
  status              EnrollmentStatus @default(active)
  scoreBand           ScoreBand?       @map("score_band")
  messagesSentCount   Int              @default(0) @map("messages_sent_count")
  lastEventAt         DateTime         @default(now()) @map("last_event_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentSession AssessmentSession? @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  smsMessages       SmsMessage[]

  @@unique([userId, sequenceKey, assessmentSessionId])
  @@index([status])
  @@map("funnel_enrollments")
}

model FunnelEvent {
  id                  String          @id @default(cuid())
  userId              String?         @map("user_id")
  assessmentSessionId String?         @map("assessment_session_id")
  type                FunnelEventType
  metadata            Json?
  occurredAt          DateTime        @default(now()) @map("occurred_at")

  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  assessmentSession AssessmentSession? @relation(fields: [assessmentSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([assessmentSessionId])
  @@index([type, occurredAt])
  @@map("funnel_events")
}

model ShortLink {
  slug                String           @id @db.VarChar(16)
  targetUrl           String           @map("target_url")
  userId              String?          @map("user_id")
  assessmentSessionId String?          @map("assessment_session_id")
  purpose             ShortLinkPurpose
  clickCount          Int              @default(0) @map("click_count")
  createdAt           DateTime         @default(now()) @map("created_at")

  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  assessmentSession AssessmentSession? @relation(fields: [assessmentSessionId], references: [id], onDelete: SetNull)

  @@index([assessmentSessionId])
  @@map("short_links")
}

model SmsOptOut {
  phone     String   @id
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sms_opt_outs")
}

model SmsFunnelStepConfig {
  id          String   @id @default(cuid())
  sequenceKey String   @map("sequence_key")
  stepKey     String   @map("step_key")
  body        String?
  bodyLow     String?  @map("body_low")
  bodyMedium  String?  @map("body_medium")
  bodyHigh    String?  @map("body_high")
  delayMs     Int?     @map("delay_ms")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([sequenceKey, stepKey])
  @@map("sms_funnel_step_configs")
}

model SmsFunnelSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sms_funnel_settings")
}

model LeadSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lead_settings")
}

model LeadActivity {
  id                    String           @id @default(cuid())
  consultationRequestId String           @map("consultation_request_id")
  staffUserId           String?          @map("staff_user_id")
  type                  LeadActivityType
  detail                String?
  createdAt             DateTime         @default(now()) @map("created_at")

  consultationRequest ConsultationRequest @relation(fields: [consultationRequestId], references: [id], onDelete: Cascade)
  staffUser           StaffUser?          @relation(fields: [staffUserId], references: [id], onDelete: SetNull)

  @@index([consultationRequestId])
  @@map("lead_activities")
}
